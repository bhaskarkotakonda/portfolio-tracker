# Finance Tracker autopilot environment template
# Copy to .env and fill values before running autopilot:
#   cp .env.autopilot.example .env
# Free-only default: enabled (no paid market/news/LLM APIs required).

########################################
# 1) App runtime
########################################
APP_ENV=production
USE_FREE_ONLY=true

# Feature switches
ENABLE_TELEGRAM=true
ENABLE_LLM_PIPELINE=false
MARKET_DATA_PROVIDER=yfinance
NEWS_PROVIDER=none
LLM_PROVIDER=none
# Public base URL of your Cloudflare Pages app (after deployment)
# Get from: Cloudflare Dashboard -> Workers & Pages -> <your-pages-project> -> Domains
APP_BASE_URL=https://your-app.pages.dev

# Worker/API URL (if separate from APP_BASE_URL)
# Get from: Cloudflare Dashboard -> Workers & Pages -> <your-worker> -> Triggers
API_BASE_URL=https://your-worker.your-subdomain.workers.dev

# Timezone used for jobs, snapshots, and display labels
APP_TIMEZONE=America/New_York

########################################
# 2) Cloudflare account + deploy auth
########################################
# Get all three from:
# Cloudflare Dashboard -> Manage Account -> Account API Tokens
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=

# Optional: set if using Cloudflare Access in front of app routes
# Get from: Cloudflare Zero Trust -> Settings -> Custom Pages / Team domain
CLOUDFLARE_ACCESS_TEAM_DOMAIN=

########################################
# 3) Cloudflare data plane resources
########################################
# D1 database ID and binding name
# Create/find at: Workers & Pages -> D1 SQL Database
D1_DATABASE_ID=
D1_DATABASE_BINDING=DB

# R2 buckets for immutable raw uploads and backups
# Create/find at: Workers & Pages -> R2
R2_RAW_BUCKET=finance-tracker-raw
R2_BACKUP_BUCKET=finance-tracker-backups

# Queue for async tweet/research jobs
# Create/find at: Workers & Pages -> Queues
QUEUE_JOBS_NAME=finance-tracker-jobs

########################################
# 4) Telegram bot integration
########################################
# 1) Create bot with @BotFather, copy token.
# 2) Set webhook to: https://<worker>/webhooks/telegram?secret=<token>
# 3) Get chat ID by messaging the bot and checking getUpdates output.
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_DEFAULT_CHAT_ID=

########################################
# 5) Market/news/LLM providers
########################################
# Optional in paid mode only (set USE_FREE_ONLY=false if used)
# Polygon API key:
# https://polygon.io/dashboard/api-keys
POLYGON_API_KEY=

# NewsAPI key:
# https://newsapi.org/register
NEWSAPI_API_KEY=

# Anthropic API key:
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Optional LLM model overrides
ANTHROPIC_MODEL_EXTRACT=claude-sonnet-4-6
ANTHROPIC_MODEL_RESEARCH=claude-opus-4-7

########################################
# 6) Broker source metadata defaults
########################################
# Morgan Stanley static fallback (used when no statement paste is provided)
MORGAN_STANLEY_DEFAULT_TICKER=MSFT
MORGAN_STANLEY_DEFAULT_SHARES=

# Fidelity account display label
FIDELITY_ACCOUNT_LABEL="Fidelity Roth IRA"

# Robinhood account display label
ROBINHOOD_ACCOUNT_LABEL="Robinhood Taxable"

########################################
# 7) Automation and hardening
########################################
# Cron expressions for refresh jobs (UTC in Cloudflare Cron)
CRON_PRICES="0 22 * * 1-5"
CRON_FUNDAMENTALS="0 3 * * 1"
CRON_D1_BACKUP="30 5 * * *"

# Retries for queue consumers
QUEUE_MAX_RETRIES=5

# Basic app auth guard (single-user mode)
OWNER_EMAIL=

########################################
# 8) GitHub Actions deployment (optional)
########################################
# Add these as GitHub repo secrets if using CI deploy:
# CLOUDFLARE_API_TOKEN, CLOUDFLARE_ACCOUNT_ID
GITHUB_REPO=
